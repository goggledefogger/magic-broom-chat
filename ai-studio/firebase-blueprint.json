{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the chat application",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "status": { "type": "string", "enum": ["online", "offline", "idle"] },
        "lastSeen": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "displayName", "status", "lastSeen"]
    },
    "Channel": {
      "title": "Channel",
      "description": "A chat channel",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "createdBy", "createdAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A message in a channel",
      "type": "object",
      "properties": {
        "channelId": { "type": "string" },
        "text": { "type": "string" },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhotoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["channelId", "text", "authorId", "authorName", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "channels/{channelId}": {
      "schema": { "$ref": "#/entities/Channel" },
      "description": "Chat channels"
    },
    "messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Chat messages"
    }
  }
}
